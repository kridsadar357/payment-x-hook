# Neon / Postgres — อย่าคอมมิตค่าจริง
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Secret สำหรับ webhook notify (ส่งผ่าน header: x-webhook-secret)
# ใน production จำเป็นต้องตั้งค่านี้
# WEBHOOK_SECRET="paste-a-long-random-secret-here"
# และควรส่ง header เพิ่มเพื่อกัน replay:
#   x-webhook-timestamp: unix seconds หรือ milliseconds
#   x-webhook-nonce: random string ไม่ซ้ำต่อ request
#
# (optional tune)
# WEBHOOK_RATE_LIMIT_PER_MINUTE=60
# WEBHOOK_ALLOWED_SKEW_MS=90000
# WEBHOOK_NONCE_TTL_MS=300000
# WEBHOOK_REQUIRE_REPLAY_PROTECTION=1

# iOS Shortcuts relay (static header friendly)
# เรียกผ่าน /api/payments/notify-relay/<slug> และส่ง header: x-relay-secret
# ถ้าไม่ตั้ง จะ fallback ไปใช้ WEBHOOK_SECRET
# WEBHOOK_RELAY_SECRET="another-long-random-secret"

# (ทางเลือก) ค่า default ให้ตรงกับ path Shortcut เช่น /api/payments/notify/ev/2 — ใช้เมื่อไม่ได้ใส่ ?hook= บนหน้าชำระ
# NEXT_PUBLIC_PAYMENT_NOTIFY_SLUG=ev/2
